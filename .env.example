# ─── GMAIL API ───
GMAIL_CREDENTIALS_PATH=credentials/gmail_oauth.json
GMAIL_TOKEN_PATH=credentials/gmail_token.json
GMAIL_USER_ID=me
GMAIL_POLL_INTERVAL_MINUTES=15

# ─── OPENAI API (para clasificador LLM) ───
# Obtén tu API key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-tu-api-key-aqui
LLM_MODEL=gpt-4o-mini

# ─── READYCLOUD API ───
# Obtén client_id y client_secret en ReadyCloud → API Keys
# El org_pk lo obtienes de GET /api/v2/orgs/ con tu token
READYCLOUD_CLIENT_ID=tu-client-id
READYCLOUD_CLIENT_SECRET=tu-client-secret
READYCLOUD_ORG_PK=tu-org-pk
READYCLOUD_SYNC_INTERVAL_HOURS=6

# ─── UPS API (Rates + Tracking) ───
# Registrarse en: https://developer.ups.com/
UPS_CLIENT_ID=tu-ups-client-id
UPS_CLIENT_SECRET=tu-ups-client-secret
UPS_USE_SANDBOX=true

# ─── USPS API (Rates + Tracking) ───
# Registrarse en: https://www.usps.com/business/api-access.htm
USPS_CLIENT_ID=tu-usps-client-id
USPS_CLIENT_SECRET=tu-usps-client-secret
USPS_MAILER_ID=tu-mid-aqui

# ─── FEDEX API (Tracking only) ───
# Registrarse en: https://developer.fedex.com/
FEDEX_API_KEY=tu-fedex-api-key
FEDEX_SECRET_KEY=tu-fedex-secret-key
FEDEX_ACCOUNT_NUMBER=tu-fedex-account

# ─── SISTEMA ───
DATABASE_PATH=data/mardior.db
API_HOST=0.0.0.0
API_PORT=8000

# Hash bcrypt de la contraseña del dashboard
# Generalo con: mardior --hash-password tu_password
DASHBOARD_PASSWORD_HASH=

# Clave secreta para sesiones (genera una aleatoria con: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET_KEY=cambiar-esta-clave-por-una-segura

# Rate limiting: max requests per minute to /api/
RATE_LIMIT_PER_MINUTE=60

# Orígenes permitidos para CORS (formato JSON array)
CORS_ORIGINS=["http://localhost:8000"]

# Timeout de auto-shutdown en minutos (0 = sin timeout, predeterminado)
# SERVER_TIMEOUT_MINUTES=5
